{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "lib": ["es2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist",
    "removeComments": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@root/*": ["./src/*"],
      "@db/*": ["./src/db/*"],
      "@routes/*": ["./src/routes/*"],
      "@utils/*": ["./src/utils/*"],
      "@plex/*": ["./src/plex/*"],
      "@shared/*": ["./src/shared/*"],
      "@data/*": ["./src/data/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@services/*": ["./src/services/*"],
      "@/*": ["./src/client/*"]
    }
  },
  "include": ["src/**/*", "config"],
  "exclude": ["src/client/**/*"]
}
